# Optional: cloud OpenAI for fundamental JSON extraction
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Default: local Ollama (install https://ollama.com then: ollama pull llama3.2)
USE_OLLAMA=1
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2

# Optional custom user-agent string for web requests
HTTP_USER_AGENT=biotech-signal-agents/0.1
